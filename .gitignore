# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Environment secrets
.env
config/.env

# Generated data (regenerated by the pipeline / CI - not committed)
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Power BI exported CSVs are refreshed by the data-pipeline workflow;
# keep them tracked so Power BI Desktop always has the latest data,
# but ignore local scratch exports.
src/powerbi/*.csv.bak

# Logs
*.log
pipeline.log

# OS/editor
.DS_Store
.vscode/settings.json
