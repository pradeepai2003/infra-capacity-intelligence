# Copy this file to .env and fill in real values. Never commit the real .env file.

# Google AI Studio (Gemini) API key - used for AI narrative generation
GEMINI_API_KEY=YOUR_GOOGLE_API_KEY

# Ollama local server (alternative/offline narrative generation)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# Azure Storage (for Blob/CSV persistence of collected metrics)
AZURE_STORAGE_CONNECTION_STRING=your_connection_string_here
AZURE_STORAGE_CONTAINER=infra-capacity-data

# Databricks
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_token_here

# Power BI (optional, for automated dataset refresh via API)
POWERBI_WORKSPACE_ID=your_workspace_id_here
POWERBI_DATASET_ID=your_dataset_id_here